# ── Help tooltips (single-line) ────────────────────────────────────
msgid "Bu lead için NEVVA 3D mutfak planner'ını Odoo içinde aç. Müşteri bilgisi önceden doldurulur."
msgstr "Open the NEVVA 3D kitchen planner inside Odoo for this lead. Customer info is pre-filled."

msgid "Bu teklifin 3D tasarımını NEVVA planner'da yeni sekmede aç (HMAC-signed link)."
msgstr "Open this quotation's 3D design in the NEVVA Planner (new tab, HMAC-signed link)."

msgid "WebXR / AR görüntüleyicide tasarımı görüntüle (mobil cihaz önerilir)."
msgstr "View the design in the WebXR / AR viewer (mobile device recommended)."

msgid "fal.ai ile üretilmiş foto-gerçekçi render görselini aç."
msgstr "Open the photorealistic render image generated by fal.ai."

msgid "Teklifin planner'ını açar; Sürüm Geçmişi'nden bu/başka sürüme güvenle dönüp tekrar gönderebilirsin (sipariş doğrudan ezilmez)."
msgstr "Opens the quotation's planner; from Version History you can safely restore this (or another) version and re-send (the order is not overwritten directly)."

msgid "Kaydettikten sonra NEVVA'ya ping atar"
msgstr "Pings NEVVA after saving"

msgid "NEVVA .env'deki ODOO_INBOUND_SECRET ile aynı olmalı"
msgstr "Must match ODOO_INBOUND_SECRET in NEVVA's .env"

msgid "NEVVA planner adresi, örn. https://planner.electro-cuisine.be"
msgstr "NEVVA Planner address, e.g. https://planner.electro-cuisine.be"

# ── Tamamlama: UserError + uyarı bandı + uzun help ──
msgid "Uyarı"
msgstr "Warning"

msgid "Bu tasarım NEVVA Planner'da değiştirildi ancak değişiklikler henüz gönderilmedi — bu teklifteki satırlar/görseller güncel olmayabilir. Güncel tasarımı görmek için \"NEVVA Planner'da Aç\" butonunu kullanın."
msgstr "This design was modified in NEVVA Planner but the changes have not been sent yet — the lines/images in this quotation may be out of date. Use the \"Open in NEVVA Planner\" button to see the current design."

msgid "NEVVA Planner yalnız satış ekibi tarafından açılabilir."
msgstr "NEVVA Planner can only be opened by the sales team."

msgid "NEVVA Planner yapılandırılmadı.\nSettings → NEVVA Planner bölümünden URL ve Inbound Secret girin."
msgstr "NEVVA Planner is not configured.\nEnter the URL and Inbound Secret in Settings → NEVVA Planner."

msgid "NEVVA Planner başlatılamadı: %s"
msgstr "Could not start NEVVA Planner: %s"

msgid "NEVVA geçerli bir redirect_url döndürmedi."
msgstr "NEVVA did not return a valid redirect URL."

msgid "NEVVA güvensiz redirect_url döndürdü (scheme: %s)"
msgstr "NEVVA returned an unsafe redirect URL (scheme: %s)"

msgid "NEVVA başka bir host'a redirect döndürdü: %s"
msgstr "NEVVA returned a redirect to another host: %s"

msgid "Bu teklife bağlı bir %s linki yok."
msgstr "No %s link is attached to this quotation."

msgid "Bu satır NEVVA tasarımına bağlı bir teklife ait — doğrudan düzenlenemez. Değişiklik için NEVVA planner'da düzenleyip 'Envoyer' ile yeniden gönderin. (Sadece yönetici doğrudan değiştirebilir.)"
msgstr "This line belongs to a quotation linked to a NEVVA design — not directly editable. To change it, edit in NEVVA Planner and re-send with 'Envoyer'. (Only an administrator can edit directly.)"

msgid "Bu sürümde %s yok."
msgstr "No %s in this version."

msgid "Bu snapshot bir siparişe bağlı değil."
msgstr "This snapshot is not linked to any order."

msgid "Önce NEVVA URL girin ve kaydedin."
msgstr "First enter and save the NEVVA URL."

msgid "NEVVA'ya bağlanılamadı: %s"
msgstr "Could not connect to NEVVA: %s"

msgid "NEVVA bağlantısı"
msgstr "NEVVA connection"

msgid "Bağlantı başarılı — durum: %s"
msgstr "Connection successful — status: %s"

msgid "Müşterinin telefonunda AR (artırılmış gerçeklik) görünümü linki."
msgstr "AR (augmented reality) view link on the customer's phone."

msgid "NEVVA fiş/teknik döküm PDF'i — sekmede satır içi görüntülenir."
msgstr "NEVVA spec/technical sheet PDF — displayed inline in the tab."

msgid "Müşteri/temsilci tasarımı NEVVA Planner'da değiştirdi ama henüz Odoo'ya göndermedi. Bu tekliftekiler güncel olmayabilir."
msgstr "The customer/rep modified the design in NEVVA Planner but has not yet sent it to Odoo. The contents of this quotation may be out of date."

msgid "Bu teklifin montaj puanı hangi modül/panel/extra'lardan toplandı? NEVVA gönderiminde otomatik üretilir; satıcı bu kırılıma bakıp müşteriye fiyat itirazlarında savunma yapar."
msgstr "Which modules/panels/extras make up this quotation's installation points? Generated automatically on NEVVA send; the seller uses it to justify pricing to the customer."

msgid "İşaretli ise bu kontak NEVVA planner B2B moduna kendi e-posta + Odoo parolası ile giriş yapabilir. İşaretsiz hesaplar Odoo'da doğrulansa bile B2B planner'a alınmaz."
msgstr "If checked, this contact can log in to NEVVA Planner B2B mode with their own email + Odoo password. Unchecked accounts are not admitted to the B2B planner even if verified in Odoo."

msgid "Envoyer'a basan satıcının email'i (NEVVA tarafından current_user_obj.email veya project.staff_email'den çözülür)."
msgstr "Email of the seller who clicked Envoyer (resolved by NEVVA from current_user_obj.email or project.staff_email)."

msgid "Snapshot oluştuğunda satıcının res.users.lang kısa kodu ('fr','en',...). Form view'da satır tablosu kolon başlıklarını bu dile göre gösterir."
msgstr "Seller's res.users.lang short code at snapshot time ('fr','en',...). The line table column headers are shown in this language."

msgid "Son açılan NEVVA planner linki (bu lead için)."
msgstr "Last opened NEVVA Planner link (for this lead)."

msgid "Bu teklifi oluşturan NEVVA planner projesinin kimliği."
msgstr "ID of the NEVVA Planner project that created this quotation."

msgid "Foto-realistik AI render görselinin orijinal linki."
msgstr "Original link of the photorealistic AI render image."

msgid "NEVVA planner 3D sahnesinin ekran görüntüsü."
msgstr "Screenshot of the NEVVA Planner 3D scene."

msgid "Planner'da yeniden yüklenebilir tam proje verisi."
msgstr "Full project data, reloadable in the planner."

msgid "Proje JSON'unu dosya olarak indir."
msgstr "Download the project JSON as a file."

msgid "Tasarımı NEVVA planner'da açmak için link."
msgstr "Link to open the design in NEVVA Planner."

msgid "Tasarımın foto-realistik AI render önizlemesi."
msgstr "Photorealistic AI render preview of the design."

msgid "Envoyer öncesi nevva_render_image alanından arşivlenen PNG."
msgstr "PNG archived from the nevva_render_image field before sending."

msgid "Örn: https://planner.electro-cuisine.be"
msgstr "e.g. https://planner.electro-cuisine.be"

msgid "NEVVA .env'deki ODOO_INBOUND_SECRET ile birebir aynı olmalı."
msgstr "Must be exactly identical to ODOO_INBOUND_SECRET in NEVVA's .env."

msgid "Açıkken satıcı NEVVA-bağlı sale.order satırlarını manuel düzenleyemez (değişiklik için planner'a dön + Envoyer). XMLRPC akışları context bypass ile etkilenmez. KAPALIYKEN serbestlik var ama veri tutarlılığı satıcıya bağlı."
msgstr "When on, the seller cannot manually edit NEVVA-linked sale.order lines (to change: go back to the planner + Envoyer). XMLRPC flows are unaffected (context bypass). Off: full freedom but data consistency is up to the seller."

msgid "Açık ise satıcı (sistem yöneticisi olmayan) NEVVA-bağlı sale.order satırlarını manuel düzenleyemez — değişiklik için planner'a dönüp 'Envoyer' kullanmak zorunda. NEVVA backend XMLRPC çağrıları context flag'i ile bypass'lar.\n\nDEFAULT KAPALI: bu kısıt aktivasyon sırasında 502'ye yol açabilir (XMLRPC user'ın yetkisi/context propagation'a göre); test ortamında test edip emin olduktan sonra açın."
msgstr "When on, the seller (non-admin) cannot manually edit NEVVA-linked sale.order lines — they must return to the planner and use 'Envoyer'. NEVVA backend XMLRPC calls bypass this via a context flag.\n\nOFF BY DEFAULT: this restriction can cause a 502 on activation (depending on the XMLRPC user's rights / context propagation); test in a test environment before enabling."

