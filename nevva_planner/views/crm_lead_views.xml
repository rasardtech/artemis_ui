<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_view_form_nevva" model="ir.ui.view">
        <field name="name">crm.lead.form.nevva.planner</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <!-- Audit 6.1: fa-external-link Odoo konvansiyonu (dış sekme açan eylem) -->
                <button name="action_open_nevva_planner"
                        type="object"
                        string="NEVVA Planner"
                        class="btn-primary"
                        icon="fa-external-link"
                        help="Bu lead için NEVVA 3D mutfak planner'ını Odoo içinde aç. Müşteri bilgisi önceden doldurulur."/>
            </xpath>
            <!-- NOT: nevva_planner_url field'ı UI'da gösterilmez (1.7.4'ten itibaren).
                 Sebepler:
                   1) Token'lı URL (?t=TOKEN) CRM kullanıcısına FULL EDIT yetkisi
                      verir → security risk
                   2) Uzun URL "Date de clôture / Étiquettes" alanlarının üstüne
                      taşıp form layout'unu bozuyordu
                   3) Header'daki "NEVVA Planner" butonu zaten aynı işi yapıyor
                      (HMAC-signed URL, in-Odoo iframe ile) → field redundant
                 Field DB'de saklı kalır (geriye uyumluluk, audit trail). -->

            <!-- NEVVA Social Studio funnel attribution (v17.0.2.0.0+) — UTM
                 parametreleri readonly görünür; "Internal Notes" sekmesinin
                 içine küçük bir bilgi grubu. Website form'undan gelen değerleri
                 satıcı görür, hangi sosyal post'tan geldiğini bilir. -->
            <xpath expr="//page[@name='internal_notes']" position="inside">
                <group string="NEVVA Social Studio — Trafik Kaynağı"
                       invisible="not x_utm_campaign">
                    <field name="x_utm_source"   readonly="1"/>
                    <field name="x_utm_medium"   readonly="1"/>
                    <field name="x_utm_campaign" readonly="1"
                           help="post_&lt;id8&gt; formatında ise NEVVA SocialPost'tan geldi"/>
                    <field name="x_utm_content"  readonly="1"/>
                    <field name="x_nevva_attribution_sent" readonly="1"
                           help="NEVVA webhook bildirimi yapıldı mı (idempotent)"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
