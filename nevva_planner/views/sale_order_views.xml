<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_form_nevva" model="ir.ui.view">
        <field name="name">sale.order.form.nevva.planner</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- "Bekleyen değişiklik" uyarı bandı — müşteri planner'da düzenleyip
                 göndermediğinde teklifin üstünde görünür. -->
            <xpath expr="//header" position="after">
                <div class="alert alert-warning text-center mb-0" role="alert"
                     invisible="not nevva_pending">
                    <i class="fa fa-exclamation-triangle me-1"/>
                    Bu tasarım NEVVA Planner'da değiştirildi ancak değişiklikler
                    henüz gönderilmedi — bu teklifteki satırlar/görseller güncel
                    olmayabilir. Güncel tasarımı görmek için
                    <b>"NEVVA Planner'da Aç"</b> butonunu kullanın.
                </div>
            </xpath>

            <!-- Header butonları: tasarım/AR/render hızlı erişim
                 Audit 6.1: fa-external-link → dış sekme açan eylemler için Odoo konvansiyonu -->
            <xpath expr="//header" position="inside">
                <button name="action_open_nevva_planner_so"
                        type="object"
                        string="NEVVA Planner'da Aç"
                        class="btn-secondary"
                        icon="fa-external-link"
                        help="Bu teklifin 3D tasarımını NEVVA planner'da yeni sekmede aç (HMAC-signed link)."
                        invisible="not nevva_project_id and not nevva_planner_url"/>
                <button name="action_open_nevva_ar"
                        type="object"
                        string="AR'da Gör"
                        class="btn-secondary"
                        icon="fa-vr-cardboard"
                        help="WebXR / AR görüntüleyicide tasarımı görüntüle (mobil cihaz önerilir)."
                        invisible="not nevva_ar_url"/>
                <button name="action_open_nevva_render"
                        type="object"
                        string="AI Render"
                        class="btn-secondary"
                        icon="fa-image"
                        help="fal.ai ile üretilmiş foto-gerçekçi render görselini aç."
                        invisible="not nevva_render_url"/>
            </xpath>

            <!-- Sheet button_box'a smart button: NEVVA Geçmişi (snapshot sayısı badge)
                 Audit: target='new' modal popup, kanban + form view kullanıcıya
                 her güncellemenin render thumbnail + tarih + toplamını gösterir. -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_nevva_snapshots"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-history"
                        invisible="nevva_snapshot_count == 0">
                    <field name="nevva_snapshot_count" widget="statinfo"
                           string="NEVVA Geçmişi"/>
                </button>
            </xpath>

            <!-- Sipariş satırları sekmesinden sonra "NEVVA Tasarım" sekmesi -->
            <xpath expr="//notebook/page[1]" position="after">
                <page string="NEVVA Tasarım" name="nevva_design"
                      invisible="not nevva_project_id">
                    <group>
                        <group string="Proje">
                            <field name="nevva_project_id" readonly="1"/>
                            <field name="opportunity_id" string="Kaynak CRM Fırsatı"
                                   readonly="1" invisible="not opportunity_id"/>
                            <field name="nevva_pending" readonly="1"/>
                        </group>
                        <group string="Bağlantılar">
                            <field name="nevva_planner_url" widget="url" readonly="1"
                                   invisible="not nevva_planner_url"/>
                            <field name="nevva_ar_url" widget="url" readonly="1"
                                   invisible="not nevva_ar_url"/>
                            <field name="nevva_render_url" widget="url" readonly="1"
                                   invisible="not nevva_render_url"/>
                        </group>
                    </group>
                    <group string="Görseller">
                        <field name="nevva_render_image" widget="image"
                               options="{'size': [400, 300]}"
                               invisible="not nevva_render_image"/>
                        <field name="nevva_screenshot" widget="image"
                               options="{'size': [400, 300]}"
                               invisible="not nevva_screenshot"/>
                    </group>
                    <group string="Sipariş PDF" invisible="not nevva_pdf">
                        <field name="nevva_pdf_filename" invisible="1"/>
                        <field name="nevva_pdf" widget="pdf_viewer"
                               filename="nevva_pdf_filename"/>
                    </group>
                    <group string="Proje Verisi"
                           invisible="not nevva_project_json">
                        <field name="nevva_project_json" invisible="1"/>
                        <field name="nevva_project_json_filename" invisible="1"/>
                        <field name="nevva_project_json_file"
                               filename="nevva_project_json_filename" readonly="1"/>
                    </group>
                    <group string="Montaj Puanı Kırılımı"
                           invisible="not nevva_installation_breakdown">
                        <field name="nevva_installation_breakdown"
                               readonly="1" nolabel="1"
                               class="o_nevva_breakdown"/>
                    </group>
                    <!-- Customer Install Gallery (v17.0.2.1.0+) — gerçek kurulum
                         fotoğraflarını NEVVA Social Studio'ya gönder -->
                    <group string="📸 Sosyal Medya — Gerçek Kurulum Fotoğrafları">
                        <field name="nevva_install_consent"/>
                        <field name="nevva_install_sent" readonly="1"/>
                        <div colspan="2" class="text-muted" style="font-size:12px">
                            Bu siparişe sohbet/ek bölümünden gerçek kurulum fotoğrafları yükle
                            (dosya adı 'nevva' içermesin), müşteri onayını al + yukarıdaki kutuyu
                            işaretle, sonra butona bas. Fotoğraflar NEVVA Social Studio'da
                            "📸 Kurulum" kütüphanesine düşer — render'dan 3-5x daha çok dönüşüm.
                        </div>
                        <button name="action_send_install_photos"
                                type="object"
                                string="📸 Kurulum Fotoğraflarını NEVVA'ya Gönder"
                                class="btn-primary"
                                colspan="2"
                                confirm="Müşteri onayı alındı mı? Fotoğraflar NEVVA sosyal medya kütüphanesine gönderilecek."
                                invisible="not nevva_install_consent"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
