<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban view — popup'ta her snapshot bir kart (sipariş satırı gibi) -->
    <record id="view_nevva_sale_snapshot_kanban" model="ir.ui.view">
        <field name="name">nevva.sale.snapshot.kanban</field>
        <field name="model">nevva.sale.snapshot</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard o_nevva_snapshot_kanban"
                    default_order="created_at desc" create="false">
                <field name="id"/>
                <field name="created_at"/>
                <field name="sender_email"/>
                <field name="amount_total"/>
                <field name="amount_untaxed"/>
                <field name="currency_name"/>
                <field name="line_count"/>
                <field name="render_attachment_id"/>
                <field name="render_thumbnail_url"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click"
                             style="display:flex;gap:14px;padding:12px;border:1px solid #e5e7eb;border-radius:8px;margin:6px;">
                            <!-- Render thumbnail (sol) -->
                            <div style="flex:0 0 140px;height:100px;border:1px solid #e5e7eb;border-radius:6px;background:#fafafa;overflow:hidden;display:flex;align-items:center;justify-content:center">
                                <img t-if="record.render_attachment_id.raw_value"
                                     t-att-src="record.render_thumbnail_url.raw_value"
                                     style="width:100%;height:100%;object-fit:cover"
                                     alt="Render"/>
                                <span t-if="!record.render_attachment_id.raw_value"
                                      style="color:#999;font-size:11px">Render yok</span>
                            </div>
                            <!-- Metadata (orta) -->
                            <div style="flex:1;min-width:0">
                                <div style="font-weight:600;font-size:14px;color:#111">
                                    <i class="fa fa-clock-o me-1"/>
                                    <field name="created_at"/>
                                </div>
                                <div style="font-size:13px;color:#666;margin-top:4px">
                                    <i class="fa fa-user me-1"/>
                                    <field name="sender_email"/>
                                </div>
                                <div style="font-size:12px;color:#666;margin-top:2px">
                                    <field name="line_count"/> satır
                                </div>
                            </div>
                            <!-- Total (sağ) -->
                            <div style="flex:0 0 auto;text-align:right">
                                <div style="font-weight:700;font-size:16px;color:#0d6efd">
                                    <field name="amount_total"/>
                                    <field name="currency_name"/>
                                </div>
                                <div style="font-size:11px;color:#999;margin-top:2px">
                                    HT: <field name="amount_untaxed"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Tree view — fallback / list mode -->
    <record id="view_nevva_sale_snapshot_tree" model="ir.ui.view">
        <field name="name">nevva.sale.snapshot.tree</field>
        <field name="model">nevva.sale.snapshot</field>
        <field name="arch" type="xml">
            <tree default_order="created_at desc" create="false">
                <field name="created_at" string="Tarih"/>
                <field name="sender_email" string="Gönderen"/>
                <field name="language" string="Dil"/>
                <field name="line_count" string="Satır Sayısı"/>
                <field name="amount_untaxed" string="HT Tutar" sum="HT Toplam"/>
                <field name="amount_total" string="TTC Tutar" sum="TTC Toplam"/>
                <field name="currency_name" string="Para Birimi"/>
            </tree>
        </field>
    </record>

    <!-- Form view — bir snapshot detay popup'ı -->
    <record id="view_nevva_sale_snapshot_form" model="ir.ui.view">
        <field name="name">nevva.sale.snapshot.form</field>
        <field name="model">nevva.sale.snapshot</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" duplicate="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Bilgiler">
                            <field name="created_at" string="Tarih" readonly="1"/>
                            <field name="sender_email" string="Gönderen" readonly="1"/>
                            <field name="language" string="Dil" readonly="1"/>
                            <field name="sale_order_id" string="Sipariş" readonly="1"/>
                        </group>
                        <group string="Tutarlar">
                            <field name="amount_untaxed" string="HT Tutar" readonly="1"/>
                            <field name="amount_total" string="TTC Tutar" readonly="1"/>
                            <field name="currency_name" string="Para Birimi" readonly="1"/>
                            <field name="line_count" string="Satır Sayısı" readonly="1"/>
                        </group>
                    </group>

                    <group string="Eski Render" invisible="not render_attachment_id">
                        <field name="render_attachment_id" invisible="1"/>
                        <div colspan="2">
                            <img t-att-src="'/web/image/' + (record.render_attachment_id and record.render_attachment_id[0] or 0)"
                                 style="max-width:600px;border:1px solid #e5e7eb;border-radius:8px"
                                 alt="Eski render"/>
                        </div>
                        <field name="render_url" string="Eski Render URL"
                               widget="url" readonly="1"
                               invisible="not render_url"/>
                    </group>

                    <group string="Eski Sipariş Satırları">
                        <field name="lines_html" nolabel="1" readonly="1"/>
                    </group>

                    <group string="Eski Dosyalar">
                        <field name="pdf_attachment_id" string="Eski BOM PDF" readonly="1"
                               invisible="not pdf_attachment_id"/>
                        <field name="json_attachment_id" string="Eski Proje JSON" readonly="1"
                               invisible="not json_attachment_id"/>
                        <field name="screenshot_attachment_id" string="Eski Ekran Görüntüsü" readonly="1"
                               invisible="not screenshot_attachment_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
